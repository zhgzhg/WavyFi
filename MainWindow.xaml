<Window x:Class="WavyFi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WavyFi.Controls"
        Title="WavyFi" Height="760" Width="1180"
        Background="#1E1E24" Foreground="#E8E8EC">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8E8EC"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9BB4D9"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#2C2C36"/>
            <Setter Property="Foreground" Value="#9BB4D9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#3A3A46"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#26262E"/>
            <Setter Property="Foreground" Value="#E8E8EC"/>
            <Setter Property="CaretBrush" Value="#E8E8EC"/>
            <Setter Property="BorderBrush" Value="#3A3A46"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ScanSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="Track" Width="42" Height="20" CornerRadius="10"
                                    Background="#3A3A46" VerticalAlignment="Center">
                                <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="#8A8A94"
                                         HorizontalAlignment="Left" Margin="3,0"/>
                            </Border>
                            <TextBlock x:Name="SwitchLabel" Text="Scan OFF" MinWidth="62"
                                       Margin="8,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold" Foreground="#8A8A94"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#3A5A8C"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#E8E8EC"/>
                                <Setter TargetName="SwitchLabel" Property="Text" Value="Scan ON"/>
                                <Setter TargetName="SwitchLabel" Property="Foreground" Value="#E8E8EC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#E8E8EC"/>
            <Setter Property="Background" Value="#26262E"/>
            <Setter Property="BorderBrush" Value="#3A5A8C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="Root">
                            <ToggleButton Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="1" CornerRadius="2">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,8,0" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#8A8A94"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" Margin="8,3,24,3"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              IsHitTestVisible="False"/>
                            <Popup Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#26262E" BorderBrush="#3A3A46" BorderThickness="1">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Locked (scanning on): clearly dimmed, flat border -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                                <Setter Property="BorderBrush" Value="#3A3A46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E8E8EC"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A5A8C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="18">
                            <Border Height="4" CornerRadius="2" Background="#3A3A46"
                                    VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <!-- Threshold semantics: the accent fill sits on the
                                     PASSING side (right of the thumb = stronger signals). -->
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Rectangle Fill="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2" Background="#3A5A8C"
                                                        VerticalAlignment="Center"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="13" Height="13">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="#9BB4D9"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#9BB4D9"/>
            <Setter Property="TextDecorations" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#B8D0F0"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#E8E8EC"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#26262E" Padding="14,5"
                                Margin="0,0,2,0" CornerRadius="4,4,0,0">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A5A8C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" MinWidth="460"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="1.2*" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- Quadrants 1+2 vs 3: horizontal resize -->
        <GridSplitter Grid.Row="1" Grid.Column="1" Width="6"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Background="#2C2C36" ResizeBehavior="PreviousAndNext"/>

        <!-- Toolbar -->
        <DockPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,10">
            <ToggleButton x:Name="ScanToggle" Style="{StaticResource ScanSwitchStyle}"
                          IsChecked="True" VerticalAlignment="Center"
                          Checked="ScanToggle_Changed" Unchecked="ScanToggle_Changed"
                          DockPanel.Dock="Left"/>
            <TextBlock Text="Adapter:" VerticalAlignment="Center" Margin="14,0,6,0"
                       Foreground="#8A8A94" DockPanel.Dock="Left"/>
            <ComboBox x:Name="AdapterCombo" MinWidth="280" MaxWidth="420"
                      VerticalAlignment="Center" DockPanel.Dock="Left"
                      DisplayMemberPath="Description"
                      DropDownOpened="AdapterCombo_DropDownOpened"
                      SelectionChanged="AdapterCombo_SelectionChanged"/>
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0">
                <Hyperlink NavigateUri="https://github.com/zhgzhg/WavyFi"
                           RequestNavigate="RepoLink_RequestNavigate"
                           ToolTip="Open the project repository">
                    <Run x:Name="TitleRun" Text="WavyFi"/>
                </Hyperlink>
            </TextBlock>
            <Border/>
        </DockPanel>

        <!-- Left column: filter + table + graphs -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*" MinHeight="140"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="2*" MinHeight="160"/>
            </Grid.RowDefinitions>

            <!-- Quadrant 1 vs 2: vertical resize -->
            <GridSplitter Grid.Row="2" Height="6"
                          HorizontalAlignment="Stretch" VerticalAlignment="Center"
                          Background="#2C2C36" ResizeBehavior="PreviousAndNext"/>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource SectionHeader}" Text="NEARBY NETWORKS"/>
                <WrapPanel Margin="0,0,0,8">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#8A8A94"/>
                    <TextBox x:Name="SearchBox" Width="180" Margin="0,0,16,0"
                             TextChanged="Filter_Changed"
                             ToolTip="Filter by SSID, BSSID or vendor"/>
                    <TextBlock Text="Band:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#8A8A94"/>
                    <ComboBox x:Name="BandFilter" Width="100" Margin="0,0,16,0"
                              SelectedIndex="0" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All"/>
                        <ComboBoxItem Content="2.4 GHz"/>
                        <ComboBoxItem Content="5 GHz"/>
                        <ComboBoxItem Content="6 GHz"/>
                    </ComboBox>
                    <TextBlock Text="Signal ≥" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="#8A8A94"/>
                    <Slider x:Name="MinRssiSlider" Width="140" Minimum="-100" Maximum="-30"
                            Value="-100" VerticalAlignment="Center"
                            ToolTip="Hide networks and WiFi Direct peers weaker than this — the highlighted part of the track is what passes"
                            ValueChanged="Filter_Changed"/>
                    <TextBlock x:Name="MinRssiLabel" Text="any" VerticalAlignment="Center"
                               Margin="6,0,0,0" Foreground="#8A8A94" MinWidth="64"/>
                </WrapPanel>
            </StackPanel>

            <DataGrid x:Name="NetworksGrid" Grid.Row="1"
                      SelectionChanged="NetworksGrid_SelectionChanged"
                      PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown"
                      PreviewMouseRightButtonDown="NetworksGrid_PreviewMouseRightButtonDown"
                      ClipboardCopyMode="ExcludeHeader"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      HorizontalScrollBarVisibility="Auto" FrozenColumnCount="1"
                      CanUserReorderColumns="True"
                      Background="#26262E" Foreground="#E8E8EC" BorderThickness="0"
                      RowBackground="#26262E" AlternatingRowBackground="#2C2C36">
                <DataGrid.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="CopyCellItem" Header="Copy cell" Click="CopyCell_Click"/>
                        <MenuItem Header="Copy row(s)" Click="CopyRows_Click"/>
                        <MenuItem Header="Copy table (CSV)" Click="CopyTable_Click"/>
                        <Separator/>
                        <MenuItem Header="Export table to CSV file..." Click="ExportTable_Click"/>
                    </ContextMenu>
                </DataGrid.ContextMenu>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="(E)SSID" Binding="{Binding DisplayName}" Width="170"/>
                    <DataGridTextColumn Header="Signal (%)" Binding="{Binding SignalPercent}" Width="70"
                                        Visibility="Collapsed"/>
                    <DataGridTextColumn Header="RSSI (dBm)" Binding="{Binding Rssi}" Width="80"/>
                    <DataGridTextColumn Header="Ch" Binding="{Binding Channel}" Width="45"/>
                    <DataGridTextColumn Header="Width (MHz)" Binding="{Binding ChannelWidthMhz}" Width="90"/>
                    <DataGridTextColumn Header="Max rate (Mbps)" Binding="{Binding MaxRateMbps, StringFormat={}{0:0.#}}" Width="110"/>
                    <DataGridTextColumn Header="Freq (MHz)" Binding="{Binding FrequencyMhz}" Width="80"/>
                    <DataGridTextColumn Header="Band (GHz)" Binding="{Binding BandText}" Width="80"/>
                    <DataGridTextColumn Header="802.11" Binding="{Binding Standards}" Width="80"/>
                    <DataGridTextColumn Header="Generation" Binding="{Binding Generation}" Width="90"
                                        Visibility="Collapsed"/>
                    <DataGridTextColumn Header="Security" Binding="{Binding Security}" Width="130"/>
                    <DataGridTextColumn Header="Cipher" Binding="{Binding Cipher}" Width="85"/>
                    <DataGridTextColumn Header="WPS" Binding="{Binding WpsVersion}" Width="45"/>
                    <DataGridTextColumn Header="Legacy rates (Mbps)" Binding="{Binding RatesCsv}" Width="170"/>
                    <DataGridTextColumn Header="BSSID" Binding="{Binding Bssid}" Width="135"/>
                    <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="150"/>
                    <DataGridTextColumn Header="Last seen (s)" Binding="{Binding LastSeenSeconds}" Width="90"/>
                </DataGrid.Columns>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="#26262E"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                <Setter Property="Background" Value="#1F3A2A"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsStale}" Value="True">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <TabControl x:Name="GraphTabs" Grid.Row="3" Background="Transparent"
                        BorderThickness="0" Padding="0">
                <TabItem Header="2.4 GHz">
                    <controls:ChannelGraph x:Name="Graph24" Band="2.4 GHz"/>
                </TabItem>
                <TabItem Header="5 GHz">
                    <controls:ChannelGraph x:Name="Graph5" Band="5 GHz"/>
                </TabItem>
                <TabItem Header="6 GHz">
                    <controls:ChannelGraph x:Name="Graph6" Band="6 GHz"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Right column: WiFi Direct + signal graph + recommendations -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="1.4*"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="170"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}"
                           Text="WIFI DIRECT DEVICES"/>
                <DataGrid x:Name="PeersGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          HorizontalScrollBarVisibility="Auto"
                          ClipboardCopyMode="ExcludeHeader"
                          CanUserReorderColumns="True" FontSize="11"
                          PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown"
                          PreviewMouseRightButtonDown="PeersGrid_PreviewMouseRightButtonDown"
                          Background="#26262E" Foreground="#E8E8EC" BorderThickness="0"
                          RowBackground="#26262E" AlternatingRowBackground="#2C2C36">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Copy device info" Click="CopyPeer_Click"/>
                            <MenuItem Header="Copy list" Click="CopyPeerList_Click"/>
                            <Separator/>
                            <MenuItem Header="Export list to CSV file..." Click="ExportPeers_Click"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="110"/>
                        <DataGridTextColumn Header="RSSI (dBm)" Binding="{Binding SignalText}"
                                            SortMemberPath="SignalDbm" Width="75"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding DeviceType}" Width="85"/>
                        <DataGridTextColumn Header="Paired" Binding="{Binding PairedText}" Width="50"/>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor}" Width="110"/>
                        <DataGridTextColumn Header="MAC" Binding="{Binding Address}" Width="115"/>
                        <DataGridTextColumn Header="Last seen (s)" Binding="{Binding LastSeenSeconds}" Width="80"/>
                    </DataGrid.Columns>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#26262E"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStale}" Value="True">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </DockPanel>

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}"
                           Text="SIGNAL OVER TIME"/>
                <controls:SignalGraph x:Name="SignalGraphView"
                                      ContextMenuOpening="SignalGraph_ContextMenuOpening">
                    <controls:SignalGraph.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="ExportHistoryItem"
                                      Header="Export history to CSV file..."
                                      Click="ExportHistory_Click"/>
                        </ContextMenu>
                    </controls:SignalGraph.ContextMenu>
                </controls:SignalGraph>
            </DockPanel>

            <DockPanel Grid.Row="4">
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource SectionHeader}"
                           Text="RECOMMENDATIONS"/>
                <Border Background="#26262E" Padding="10">
                    <TextBox x:Name="AdviceText" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             Text="Waiting for first scan..."/>
                </Border>
            </DockPanel>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#26262E"
                Padding="10,5" Margin="0,10,0,0">
            <DockPanel>
                <TextBlock x:Name="StatsText" DockPanel.Dock="Right"
                           Foreground="#8A8A94" Text=""/>
                <TextBlock x:Name="StatusText" Foreground="#8A8A94" Text="Starting..."/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
